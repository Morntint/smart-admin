# ─── PHP / 框架运行时 ────────────────────────────────────
/runtime/
/vendor/

# ─── IDE / 编辑器 ────────────────────────────────────────
/.idea/
/.vscode/

# ─── 日志 / 临时 ─────────────────────────────────────────
*.log
/runtime/logs/
/tests/tmp/
/tests/.phpunit.result.cache

# ─── 环境变量（含敏感信息，禁止提交） ─────────────────────
.env
.env.local
.env.*.local

# ─── 上传目录（运行时数据，按需 ignore） ──────────────────
/public/uploads/

# ─── 生成产物 ───────────────────────────────────────────
/public/openapi.json
/public/openapi.yaml

# ─── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── 单元测试缓存 ───────────────────────────────────────────
/.phpunit.cache/
