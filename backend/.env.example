# ─── 应用 ────────────────────────────────────────────────────
APP_DEBUG=false
APP_ENV=production
APP_URL=http://localhost:8787

# ─── 数据库（MySQL） ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webman_admin
DB_USERNAME=root
DB_PASSWORD=
# 读写分离（可选）：设置 DB_READ_HOST 即启用；多个从库用逗号分隔。
#   留空则单库模式。详见 docs/READ_WRITE_SPLIT.md
DB_READ_HOST=
# DB_WRITE_HOST=          # 主库地址，缺省回退 DB_HOST
# DB_STICKY=true          # 同请求写后读走主库，避免主从延迟读到旧数据

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── 缓存（file / redis / array） ─────────────────────────────
# 高并发/多进程下建议用 redis：限流、幂等、缓存互斥锁均依赖 Redis，
# file 驱动仅适合单机低并发或本地开发。
CACHE_DRIVER=file
CACHE_PREFIX=webman_cache

# ─── JWT ─────────────────────────────────────────────────────
# 生产环境务必修改 JWT_SECRET，长度不少于 32 字符
# 生成示例：openssl rand -hex 32
JWT_SECRET=please-change-this-secret-key-to-at-least-32-chars
JWT_EXPIRE=7200
JWT_ISSUER=admin

# ─── 对称加密密钥（AES-256-GCM） ──────────────────────────────
# 用于 AI 模型 API Key、第三方账号密钥等敏感字段的"写入即加密、按需解密"。
# 生产环境强烈建议单独配置（与 JWT_SECRET 分离）：
#   生成示例：openssl rand -base64 32
# 留空则回退到 JWT_SECRET 派生，灰度迁移期可接受，但长期不推荐。
APP_CRYPTO_KEY=

# ─── CORS 跨域白名单（逗号分隔） ──────────────────────────────
# 留空 = 仅同源（推荐生产值，最安全）；
# 显式列举 = 多个 origin 用逗号分隔，例：https://admin.example.com,https://app.example.com
# 设为 "*" 时强制不带 cookie（浏览器规范不允许 `*` + credentials）
CORS_ALLOW_ORIGINS=

# ─── 文件上传 ────────────────────────────────────────────────
# 也可以通过 sys_config 表运行时修改：
#   upload_image_size  / upload_file_size / upload_allowed_ext
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOW_EXT=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_PATH=public/uploads

# ─── 并发 / 协程（高并发可选） ────────────────────────────────
# WM_EVENT_LOOP：留空=同步多进程模型（默认，稳定）；
#   设为 Swoole（需 ext-swoole>=5）或 Swow 启用协程驱动，连接池才生效。
#   切换前请阅读 docs/COROUTINE.md，并先用压测验证。
WM_EVENT_LOOP=
WORKER_COUNT=
# 连接池（仅协程驱动下生效）
DB_POOL_MAX=5
DB_POOL_MIN=1
REDIS_POOL_MAX=5
REDIS_POOL_MIN=1

# ─── 可观测性 ────────────────────────────────────────────────
# 访问日志：每个请求落一条带 request_id 的日志，便于 log:trace 串链路。
#   开发期建议 true；高并发生产按需开启（日志量较大）。
ACCESS_LOG=false
# 慢查询阈值（毫秒），超过则写慢查询日志；设 0 关闭
SLOW_QUERY_MS=200
# /metrics 端点访问令牌（为空则不鉴权，生产环境务必设置）
METRICS_TOKEN=

# ─── 雪花 ID（分布式主键，可选） ──────────────────────────────
# 多实例部署时每个实例必须分配唯一 WORKER_ID（0~1023）；留空则按主机名+PID 哈希兜底
SNOWFLAKE_WORKER_ID=
# 起始纪元毫秒（可选，默认 2024-01-01）
SNOWFLAKE_EPOCH=

# ─── 微信配置 ────────────────────────────────────────────────
# 公众号
WECHAT_OFFICIAL_APPID=
WECHAT_OFFICIAL_SECRET=
WECHAT_OFFICIAL_TOKEN=
WECHAT_OFFICIAL_AES_KEY=

# 小程序
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=
WECHAT_MINI_TOKEN=
WECHAT_MINI_AES_KEY=

# 开放平台
WECHAT_OPEN_APPID=
WECHAT_OPEN_SECRET=
WECHAT_OPEN_TOKEN=
WECHAT_OPEN_AES_KEY=

# 企业微信
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_SECRET=
WECHAT_WORK_TOKEN=
WECHAT_WORK_AES_KEY=

# 微信支付（EasyWeChat 6 / API v3）
# ⚠ 不要把真实的 SECRET / PRIVATE KEY / CERTIFICATE 写入 .env 提交到代码库——
#    生产环境请使用 docker secrets / vault / 受限文件路径管理。
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SECRET_KEY=
WECHAT_PAY_V3_KEY=
# 商户私钥（推荐填写文件绝对路径，例如 /etc/wechat-pay/apiclient_key.pem）
WECHAT_PAY_PRIVATE_KEY=
# 商户证书（推荐填写文件绝对路径，例如 /etc/wechat-pay/apiclient_cert.pem）
WECHAT_PAY_CERTIFICATE=
WECHAT_PAY_NOTIFY_URL=

