# ─── 应用 ────────────────────────────────────────────────────
APP_DEBUG=false
APP_ENV=production
APP_URL=http://localhost:8787

# ─── 数据库（MySQL） ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webman_admin
DB_USERNAME=root
DB_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── 缓存（file / redis / array） ─────────────────────────────
CACHE_DRIVER=file
CACHE_PREFIX=webman_cache

# ─── JWT ─────────────────────────────────────────────────────
# 生产环境务必修改 JWT_SECRET，长度不少于 32 字符
# 生成示例：openssl rand -hex 32
JWT_SECRET=please-change-this-secret-key-to-at-least-32-chars
JWT_EXPIRE=7200
JWT_ISSUER=admin

# ─── 文件上传 ────────────────────────────────────────────────
# 也可以通过 sys_config 表运行时修改：
#   upload_image_size  / upload_file_size / upload_allowed_ext
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOW_EXT=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_PATH=public/uploads
